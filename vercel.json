{
  "version": 2,
  "builds": [
    {
      "src": "demo-server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "merchant/**",
          "cliente/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/demo-server.js"
    }
  ]
}
